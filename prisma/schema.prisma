// AquaFotos 2.0 – Enterprise Schema
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  PHOTOGRAPHER
  EDITOR
  CUSTOMER
  PARTNER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  familyAccount    FamilyAccount?
  partnerProfile   Partner?
  orders           Order[]
  notifications    ShootingNotification[]
  individualReqs   IndividualShootingRequest[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Partner ─────────────────────────────────────────────────────────

enum PartnerType {
  SWIMMING_POOL
  KITA
  MIDWIFE
  FAMILY_CENTER
}

model Partner {
  id           String      @id @default(cuid())
  userId       String?     @unique
  name         String
  type         PartnerType
  description  String?     @db.Text
  logoUrl      String?
  address      String?
  city         String?
  postalCode   String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  websiteUrl   String?
  active       Boolean     @default(true)
  featured     Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user   User?           @relation(fields: [userId], references: [id])
  events ShootingEvent[]

  @@index([type])
  @@index([active, featured])
}

// ─── Shooting Events ─────────────────────────────────────────────────

enum ShootingCategory {
  UNDERWATER
  KITA
  BABY
  FAMILY
  COUPLE
  SEASONAL
  OTHER
}

enum ShootingType {
  UNDERWATER_BABY
  UNDERWATER_TODDLER
  UNDERWATER_CHILD
  UNDERWATER_FAMILY
  UNDERWATER_SIBLINGS
  KITA_HOLIDAY
  KITA_SIBLINGS
  KITA_GROUP
  KITA_PORTRAIT
  BABY_BELLY
  BABY_NEWBORN
  BABY_MILESTONE
  BABY_6_MONTHS
  BABY_1_YEAR
  FAMILY_OUTDOOR
  FAMILY_PARK
  FAMILY_FOREST
  FAMILY_EVENING
  COUPLE
  CHRISTMAS_MINIS
  MOTHERS_DAY
  FATHERS_DAY
  SCHOOL_ENROLLMENT
  EASTER
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  FULL
  COMPLETED
  CANCELLED
}

model ShootingEvent {
  id              String           @id @default(cuid())
  title           String
  description     String?          @db.Text
  category        ShootingCategory
  shootingType    ShootingType
  status          EventStatus      @default(DRAFT)
  date            DateTime         @db.Date
  startTime       String?
  endTime         String?
  location        String
  locationDetail  String?
  maxParticipants Int
  allowWaitlist   Boolean          @default(true)
  partnerId       String?
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  partner      Partner?      @relation(fields: [partnerId], references: [id])
  slots        EventSlot[]
  participants Participant[]
  waitlist     WaitlistEntry[]
  photos       Photo[]
  orders       Order[]

  @@index([status, date])
  @@index([shootingType])
  @@index([category])
}

model EventSlot {
  id              String   @id @default(cuid())
  eventId         String
  startTime       String
  endTime         String?
  maxParticipants Int      @default(1)
  createdAt       DateTime @default(now())

  event        ShootingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@index([eventId])
}

// ─── Participants & QR ───────────────────────────────────────────────

enum ParticipantStatus {
  INVITED
  CONFIRMED
  GALLERY_VIEWED
  ORDERED
  REMINDER_SENT
  ATTENDED
  CANCELLED
  REGISTERED
}

enum ParticipantSource {
  MANUAL
  WEBSITE
  QR_CODE
}

model FamilyAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  children     Child[]
  participants Participant[]
  galleryAccess GalleryAccess[]
  carts        Cart[]
  orders       Order[]
}

model Child {
  id              String   @id @default(cuid())
  familyAccountId String
  firstName       String
  lastName        String?
  birthDate       DateTime? @db.Date
  createdAt       DateTime @default(now())

  familyAccount FamilyAccount @relation(fields: [familyAccountId], references: [id], onDelete: Cascade)
  participants  Participant[]

  @@index([familyAccountId])
}

model Participant {
  id              String            @id @default(cuid())
  eventId         String
  slotId          String?
  familyAccountId String?
  childId         String?
  participantNumber Int
  parentName      String
  childName       String
  childAge        Int?
  email           String
  phone           String
  gdprConsent     Boolean           @default(false)
  gdprConsentAt   DateTime?
  status          ParticipantStatus @default(REGISTERED)
  registrationSource ParticipantSource @default(WEBSITE)
  confirmationSentAt DateTime?
  confirmedAt       DateTime?
  galleryViewedAt   DateTime?
  orderedAt         DateTime?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  event         ShootingEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  slot          EventSlot?     @relation(fields: [slotId], references: [id])
  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])
  child         Child?         @relation(fields: [childId], references: [id])
  qrCode        ParticipantQR?
  photos        Photo[]
  galleryAccess GalleryAccess?
  favorites     PhotoFavorite[]

  @@unique([eventId, participantNumber])
  @@index([eventId])
  @@index([email])
}

model ParticipantQR {
  id            String   @id @default(cuid())
  participantId String   @unique
  code          String   @unique
  qrDataUrl     String?  @db.Text
  pdfUrl        String?
  createdAt     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([code])
}

// ─── Waitlist & Notifications ────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  eventId   String
  parentName String
  childName  String?
  email     String
  phone     String?
  createdAt DateTime @default(now())

  event ShootingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, email])
}

model ShootingNotification {
  id           String       @id @default(cuid())
  userId       String?
  email        String
  shootingType ShootingType
  location     String?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email, shootingType])
}

model IndividualShootingRequest {
  id           String       @id @default(cuid())
  userId       String?
  parentName   String
  childName    String?
  email        String
  phone        String
  shootingType ShootingType
  preferredDate DateTime?   @db.Date
  message      String?      @db.Text
  status       String       @default("PENDING")
  confirmedDate DateTime?    @db.Date
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([status])
}

// ─── Photos & Processing ─────────────────────────────────────────────

enum PhotoProcessingStatus {
  RAW
  PRESELECTED
  EDITING
  APPROVED
  READY
}

model Photo {
  id              String                @id @default(cuid())
  eventId         String
  participantId   String?
  filename        String
  storageKey      String
  previewKey      String?
  qrDetectedCode  String?
  processingStatus PhotoProcessingStatus @default(RAW)
  sortOrder       Int                   @default(0)
  uploadedAt      DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  event       ShootingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant?  @relation(fields: [participantId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  favorites   PhotoFavorite[]

  @@index([eventId])
  @@index([participantId])
  @@index([qrDetectedCode])
}

// ─── Gallery Access ──────────────────────────────────────────────────

model GalleryAccess {
  id              String    @id @default(cuid())
  participantId   String    @unique
  familyAccountId String?
  accessCode      String    @unique
  emailVerified   Boolean   @default(false)
  verifiedAt      DateTime?
  lastAccessAt    DateTime?
  accessCount     Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])

  @@index([accessCode])
}

// ─── Shop & Pricing ──────────────────────────────────────────────────

model PricingConfig {
  id              String   @id @default(cuid())
  firstImagePrice Int      @default(3500)
  secondImagePrice Int     @default(2500)
  additionalPrice Int      @default(1500)
  currency        String   @default("EUR")
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model Cart {
  id              String   @id @default(cuid())
  familyAccountId String?
  sessionId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])
  items         CartItem[]

  @@index([sessionId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  photoId   String
  createdAt DateTime @default(now())

  cart  Cart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([cartId, photoId])
}

model PhotoFavorite {
  id            String   @id @default(cuid())
  photoId       String
  participantId String
  createdAt     DateTime @default(now())

  photo       Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([photoId, participantId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  AWAITING_PROCESSING
  IN_PROCESSING
  IN_REVIEW
  READY
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerEmail   String?
  familyAccountId String?
  userId          String?
  eventId         String?
  status          OrderStatus @default(PENDING_PAYMENT)
  subtotalCents   Int
  totalCents      Int
  currency        String      @default("EUR")
  stripeSessionId String?
  stripePaymentId String?
  bindingConfirmed Boolean    @default(false)
  isReorder       Boolean     @default(false)
  paidAt          DateTime?
  processingStartedAt DateTime?
  readyNotifiedAt DateTime?
  deliveredAt     DateTime?
  invoiceUrl      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])
  user          User?          @relation(fields: [userId], references: [id])
  event         ShootingEvent? @relation(fields: [eventId], references: [id])
  items         OrderItem[]

  @@index([status])
  @@index([orderNumber])
  @@index([customerEmail])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  photoId         String
  priceCents      Int
  position        Int
  status          OrderItemStatus @default(AWAITING_PROCESSING)
  finalStorageKey String?
  readyAt         DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ─── E-Mail Vorlagen (Admin) ─────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  subject     String
  bodyHtml    String   @db.Text
  placeholders String? @db.Text
  updatedAt   DateTime @updatedAt
}

// ─── Reviews (SEO) ───────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  quote     String   @db.Text
  author    String?
  initials  String?
  rating    Int      @default(5)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}
