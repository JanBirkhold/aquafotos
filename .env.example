# Database (required – Prisma reads .env, Next.js also reads .env.local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aquafotos?schema=public"

# Auth.js (required – generate: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend
RESEND_API_KEY=""
EMAIL_FROM="AquaFotos <noreply@aquafotos.com>"

# Uploadthing
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""
